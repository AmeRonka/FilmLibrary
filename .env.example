# Konfiguracja dla docker-compose. Skopiuj ten plik do .env (zostaje lokalnie, poza repo)
# i uzupełnij wartości.

# === Baza Postgres ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=ZmienToSilneHaslo123
POSTGRES_DB=filmlibrary

# === Aplikacja ===
# Hasło konta administratora utworzonego automatycznie przy pierwszym starcie.
# Email admina jest na sztywno: admin@filmlibrary.local
# Wymagania: min 8 znaków, wielka + mała litera, cyfra.
ADMIN_PASSWORD=Admin123!

# Token TMDB v4 (Bearer) — opcjonalny, bez niego import z TMDB nie działa,
# ale reszta aplikacji jest w pełni funkcjonalna.
# Pobierz z https://www.themoviedb.org/settings/api (API Read Access Token).
TMDB_TOKEN=
