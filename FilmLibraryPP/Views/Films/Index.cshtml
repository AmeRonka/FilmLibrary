@using FilmLibraryPP.Data
@model List<FilmLibraryPP.Models.Film>
@{
    ViewData["Title"] = "Wszystkie filmy";
    var genres = ViewBag.Genres as IEnumerable<string> ?? Enumerable.Empty<string>();
    var search = ViewBag.Search as string;
    var selectedGenre = ViewBag.Genre as string;
    var isAdmin = User.IsInRole(IdentitySeed.AdminRole);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
        @(isAdmin ? "Wszystkie filmy (admin)" : "Moja biblioteka")
        <span class="badge bg-secondary">@Model.Count</span>
    </h2>
    <div class="d-flex gap-2">
        @if (Model.Any())
        {
            <a asp-action="ExportCsv" class="btn btn-outline-secondary"><i class="bi bi-filetype-csv me-1"></i>Eksportuj CSV</a>
        }
        <a asp-action="SearchTmdb" class="btn btn-outline-primary"><i class="bi bi-cloud-download me-1"></i>Importuj z TMDB</a>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i>Dodaj film</a>
    </div>
</div>

<form method="get" class="row g-2 mb-4 p-3 bg-light rounded">
    <div class="col-md-6">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Szukaj po tytule lub reżyserze..." />
    </div>
    <div class="col-md-4">
        <select name="genre" class="form-select">
            <option value="">— wszystkie gatunki —</option>
            @foreach (var g in genres)
            {
                <option value="@g" selected="@(g == selectedGenre)">@g</option>
            }
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button type="submit" class="btn btn-primary">Filtruj</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Nie znaleziono filmów spełniających kryteria.</div>
}
else
{
    <div class="row g-3">
        @foreach (var film in Model)
        {
            <div class="col-sm-6 col-md-4 col-lg-3">
                <div class="card film-card h-100">
                    <a asp-action="Details" asp-route-id="@film.Id">
                        <img src="@film.PosterUrl" alt="@film.Title" class="card-img-top" />
                    </a>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1">@film.Title</h5>
                        <small class="text-muted mb-2">@film.Year • @film.Director</small>
                        <div class="mb-2">
                            @if (film.Genre != null)
                            {
                                <span class="badge bg-info text-dark">@film.Genre</span>
                            }
                            @if (film.IsWatched)
                            {
                                <span class="badge bg-success">Obejrzany</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Do obejrzenia</span>
                            }
                        </div>
                        @if (film.Rating != null)
                        {
                            <div class="mb-2">
                                <span class="rating"><i class="bi bi-star-fill"></i> @film.Rating</span>
                            </div>
                        }
                        @if (isAdmin && film.Owner != null)
                        {
                            <small class="text-muted mb-2"><i class="bi bi-person-circle me-1"></i>@film.Owner.Email</small>
                        }
                        <a asp-action="Details" asp-route-id="@film.Id" class="btn btn-outline-primary btn-sm mt-auto">Szczegóły</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
