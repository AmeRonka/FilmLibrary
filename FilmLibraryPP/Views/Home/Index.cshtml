@{
    ViewData["Title"] = "Strona główna";
}

<div class="hero text-center p-5 mb-4 rounded shadow-sm">
    <h1 class="display-4"><i class="bi bi-film me-2"></i>Biblioteczka Filmowa</h1>
    <p class="lead">Twoja prywatna kolekcja filmów — co już obejrzałeś, co chcesz zobaczyć, co poleciłbyś znajomym.</p>
    <a class="btn btn-primary btn-lg mt-3" asp-controller="Films" asp-action="Index">Zobacz wszystkie filmy →</a>
</div>

<div class="row text-center mt-5">
    <div class="col-md-4 mb-3">
        <div class="p-4 bg-light rounded shadow-sm h-100">
            <div class="display-4 text-primary mb-2"><i class="bi bi-collection-play"></i></div>
            <h4 class="mt-2">Twoja kolekcja</h4>
            <p class="text-muted">Dodawaj filmy ręcznie albo z bazy TMDB. Tytuł, reżyser, gatunek, ocena, recenzja — wszystko w jednym miejscu.</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="p-4 bg-light rounded shadow-sm h-100">
            <div class="display-4 text-primary mb-2"><i class="bi bi-tags"></i></div>
            <h4 class="mt-2">Listy i tagi</h4>
            <p class="text-muted">Oznaczaj jako „Do obejrzenia" lub „Obejrzane". Twórz tagi typu „Ulubione" czy „Klasyka".</p>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="p-4 bg-light rounded shadow-sm h-100">
            <div class="display-4 text-primary mb-2"><i class="bi bi-bar-chart-line"></i></div>
            <h4 class="mt-2">Statystyki</h4>
            <p class="text-muted">Wykresy gatunków, rozkład ocen, ile filmów obejrzałeś w którym roku. Eksport do CSV.</p>
        </div>
    </div>
</div>

<div class="alert alert-info mt-4 mb-0">
    <strong>Tryb demo:</strong> aplikacja korzysta z przykładowych danych w pamięci.
    Baza PostgreSQL, logowanie i integracja z TMDB pojawią się w kolejnych etapach.
</div>
