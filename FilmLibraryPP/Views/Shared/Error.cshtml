@model ErrorViewModel
@{
    ViewData["Title"] = "Błąd";
}

<div class="text-center p-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Wystąpił błąd</h1>
    <p class="lead">Coś poszło nie tak podczas przetwarzania Twojego żądania.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            ID żądania: <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-3">← Wróć na stronę główną</a>
</div>
