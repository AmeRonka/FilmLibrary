@using FilmLibraryPP.Data
@using FilmLibraryPP.Models
@using Microsoft.AspNetCore.Identity

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var isAdmin = User.IsInRole(IdentitySeed.AdminRole);
        <li class="nav-item">
            <span class="nav-link">
                <i class="bi bi-person-circle me-1"></i>@User.Identity!.Name
                @if (isAdmin)
                {
                    <span class="badge bg-warning text-dark ms-1">Admin</span>
                }
            </span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="nav-link btn btn-link">Wyloguj</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Rejestracja</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Logowanie</a>
        </li>
    }
</ul>
